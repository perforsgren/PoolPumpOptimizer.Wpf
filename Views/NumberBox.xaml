<UserControl x:Class="PoolPumpOptimizer.Wpf.Views.NumberBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="58"
             Margin="0,0,0,8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="{StaticResource BrushTextMuted}"
                   FontSize="12"
                   Margin="0,0,0,4" />

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurfaceLight}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="7">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="34" />
                </Grid.ColumnDefinitions>

                <RepeatButton Grid.Column="0"
                              Content="−"
                              Background="Transparent"
                              Foreground="{StaticResource BrushText}"
                              BorderThickness="0"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Cursor="Hand"
                              Click="MinusButton_Click">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="7,0,0,7">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#313847" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#173A55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>

                <Border Grid.Column="1"
                        BorderBrush="#333A47"
                        BorderThickness="1,0,1,0">
                    <TextBox x:Name="ValueTextBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource BrushText}"
                             CaretBrush="{StaticResource BrushText}"
                             SelectionBrush="{StaticResource BrushAccent}"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Padding="0"
                             Margin="0"
                             LostFocus="ValueTextBox_LostFocus"
                             KeyDown="ValueTextBox_KeyDown"
                             TextChanged="ValueTextBox_TextChanged" />
                </Border>

                <Border Grid.Column="2"
                        Background="#202633"
                        BorderBrush="#333A47"
                        BorderThickness="0,0,1,0">
                    <TextBlock Text="{Binding Unit, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="{StaticResource BrushTextMuted}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Border>

                <RepeatButton Grid.Column="3"
                              Content="+"
                              Background="Transparent"
                              Foreground="{StaticResource BrushText}"
                              BorderThickness="0"
                              FontSize="15"
                              FontWeight="SemiBold"
                              Cursor="Hand"
                              Click="PlusButton_Click">
                    <RepeatButton.Template>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="0,7,7,0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#313847" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#173A55" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RepeatButton.Template>
                </RepeatButton>
            </Grid>
        </Border>
    </Grid>
</UserControl>