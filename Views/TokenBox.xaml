<UserControl x:Class="PoolPumpOptimizer.Wpf.Views.TokenBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="62">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Foreground="{StaticResource BrushTextMuted}"
                   FontSize="12"
                   Margin="0,0,0,4" />

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurfaceLight}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="6">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="72" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="VisibleTextBox"
                         Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource BrushText}"
                         CaretBrush="{StaticResource BrushText}"
                         SelectionBrush="{StaticResource BrushAccent}"
                         VerticalContentAlignment="Center"
                         Padding="9,0"
                         TextChanged="VisibleTextBox_TextChanged" />

                <TextBox x:Name="MaskedTextBox"
                         Grid.Column="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource BrushTextMuted}"
                         VerticalContentAlignment="Center"
                         Padding="9,0"
                         IsReadOnly="True" />

                <Button x:Name="ToggleButton"
                        Grid.Column="1"
                        Content="Visa"
                        Padding="0"
                        Margin="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{StaticResource BrushAccent}"
                        FontWeight="SemiBold"
                        Click="ToggleButton_Click" />
            </Grid>
        </Border>
    </Grid>
</UserControl>