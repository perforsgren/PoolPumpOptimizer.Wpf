<Window x:Class="PoolPumpOptimizer.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PoolPumpOptimizer.Wpf.Views"
        Title="Poolpumpsoptimering"
        Width="1420"
        Height="900"
        MinWidth="1180"
        MinHeight="740"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Background="{StaticResource BrushBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Grid.Column="0"
                    Background="#11141A"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="20,20,18,14">
                        <TextBlock Text="Poolpump"
                                   FontSize="23"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushText}" />

                        <TextBlock Text="Optimering mot elpris"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="14,0,14,16">

                            <Border Style="{StaticResource CardCompact}">
                                <StackPanel>
                                    <TextBlock Text="Optimering"
                                               Style="{StaticResource SectionTitle}" />

                                    <views:NumberBox Label="Min drift per dygn"
                                                     Unit="h"
                                                     Value="{Binding MinRunHoursPerDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="1"
                                                     Maximum="24"
                                                     Step="1"
                                                     Decimals="0" />

                                    <views:NumberBox Label="Blocklängd"
                                                     Unit="h"
                                                     Value="{Binding PreferredBlockHours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="1"
                                                     Maximum="24"
                                                     Step="1"
                                                     Decimals="0" />

                                    <views:NumberBox Label="Max starter per dygn"
                                                     Unit="st"
                                                     Value="{Binding MaxStartsPerDay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="1"
                                                     Maximum="24"
                                                     Step="1"
                                                     Decimals="0" />

                                    <views:NumberBox Label="Extra billig gräns"
                                                     Unit="SEK"
                                                     Value="{Binding CheapPriceThresholdSekPerKwh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="-10"
                                                     Maximum="20"
                                                     Step="0.05"
                                                     Decimals="2" />

                                    <views:NumberBox Label="Min ON"
                                                     Unit="min"
                                                     Value="{Binding MinOnMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="15"
                                                     Maximum="1440"
                                                     Step="15"
                                                     Decimals="0" />

                                    <views:NumberBox Label="Min OFF"
                                                     Unit="min"
                                                     Value="{Binding MinOffMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Minimum="15"
                                                     Maximum="1440"
                                                     Step="15"
                                                     Decimals="0" />

                                    <CheckBox Content="Ignorera passerade tider"
                                              IsChecked="{Binding IgnorePastSlots}" />

                                    <Button Content="Optimera"
                                            Command="{Binding OptimizeCommand}"
                                            Style="{StaticResource PrimaryButton}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardCompact}">
                                <StackPanel>
                                    <TextBlock Text="Data"
                                               Style="{StaticResource SectionTitle}" />

                                    <Button Content="Hämta priser"
                                            Command="{Binding FetchPricesCommand}"
                                            Style="{StaticResource PrimaryButton}" />

                                    <Button Content="Inställningar"
                                            Click="SettingsButton_Click" />

                                    <Button Content="Spara inställningar"
                                            Command="{Binding SaveSettingsCommand}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- MAIN PANEL -->
            <Grid Grid.Column="1"
                  Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Columns="6"
                             Margin="0,0,0,12">

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Home" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding SelectedHomeText}"
                                       Style="{StaticResource CardValueSmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Dagens drift" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TodayRunText}" Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Morgondagens drift" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TomorrowRunText}" Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Starter idag" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding TodayStartsText}" Style="{StaticResource CardValue}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Snittpris idag" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding AverageRunPriceText}" Style="{StaticResource CardValueSmall}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <Border.ToolTip>
                            <ToolTip>
                                <StackPanel MinWidth="210">
                                    <TextBlock Text="Senast uppdaterad"
                                               Foreground="{StaticResource BrushText}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                    <TextBlock Text="{Binding LastUpdatedTooltipText}"
                                               Foreground="{StaticResource BrushTextMuted}"
                                               FontSize="12"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </ToolTip>
                        </Border.ToolTip>

                        <StackPanel>
                            <TextBlock Text="Uppdaterad" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding LastUpdatedTimeText}"
                                       Foreground="{Binding LastUpdatedBrush}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- CUSTOM TAB HEADER -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,10">
                    <RadioButton Content="Plan"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabNavButton}"
                                 IsChecked="{Binding IsPlanTabSelected, Mode=TwoWay}" />

                    <RadioButton Content="Detaljer"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabNavButton}"
                                 IsChecked="{Binding IsDetailsTabSelected, Mode=TwoWay}" />

                    <RadioButton Content="Logg"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabNavButton}"
                                 IsChecked="{Binding IsLogTabSelected, Mode=TwoWay}" />
                </StackPanel>

                <!-- CONTENT -->
                <Grid Grid.Row="2">

                    <!-- PLAN -->
                    <Grid Visibility="{Binding IsPlanVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource Card}"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0"
                                      Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="180" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Elpris med ON-perioder"
                                                   Style="{StaticResource SectionTitle}"
                                                   Margin="0,0,18,0" />

                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="0,1,0,0">
                                            <Rectangle Width="18"
                                                       Height="8"
                                                       RadiusX="3"
                                                       RadiusY="3"
                                                       Fill="#6537D67A"
                                                       Margin="0,0,6,0" />
                                            <TextBlock Text="Pump ON"
                                                       Foreground="{StaticResource BrushTextMuted}"
                                                       Margin="0,0,16,0" />

                                            <Rectangle Width="18"
                                                       Height="3"
                                                       Fill="{StaticResource BrushAccent}"
                                                       Margin="0,0,6,0" />
                                            <TextBlock Text="Pris"
                                                       Foreground="{StaticResource BrushTextMuted}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding DayFilters}"
                                              SelectedItem="{Binding SelectedDayFilter}" />
                                </Grid>

                                <views:PricePlanChart Grid.Row="1"
                                                      ItemsSource="{Binding DetailSlots}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Style="{StaticResource Card}"
                                Margin="0,8,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Sammanhängande körblock"
                                           Style="{StaticResource SectionTitle}" />

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding RunBlocks}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Datum" Binding="{Binding DateText}" Width="120" />
                                        <DataGridTextColumn Header="Start" Binding="{Binding StartText}" Width="90" />
                                        <DataGridTextColumn Header="Slut" Binding="{Binding EndText}" Width="90" />
                                        <DataGridTextColumn Header="Drift" Binding="{Binding DurationText}" Width="90" />
                                        <DataGridTextColumn Header="Snittpris" Binding="{Binding AveragePriceText}" Width="150" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- DETAILS -->
                    <Border Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource Card}"
                            Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Alla kvartar"
                                           Style="{StaticResource SectionTitle}" />

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DayFilters}"
                                          SelectedItem="{Binding SelectedDayFilter}" />
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding DetailSlots}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tid" Binding="{Binding StartsAtText}" Width="160" />
                                    <DataGridTextColumn Header="Pris" Binding="{Binding PriceText}" Width="90" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding RunText}" Width="80" />
                                    <DataGridTextColumn Header="Orsak" Binding="{Binding Reason}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <!-- LOG -->
                    <Border Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            Style="{StaticResource Card}"
                            Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Statuslogg"
                                           Style="{StaticResource SectionTitle}" />

                                <Button Grid.Column="1"
                                        Content="Rensa"
                                        Command="{Binding ClearLogCommand}" />
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding LogEntries}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tid" Binding="{Binding TimestampText}" Width="160" />
                                    <DataGridTextColumn Header="Nivå" Binding="{Binding Level}" Width="90" />
                                    <DataGridTextColumn Header="Meddelande" Binding="{Binding Message}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- FULL WIDTH STATUS BAR -->
        <Border Grid.Row="1"
                Background="#0F1217"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Status"
                           Foreground="{StaticResource BrushTextMuted}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</Window>