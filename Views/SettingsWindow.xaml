<Window x:Class="PoolPumpOptimizer.Wpf.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PoolPumpOptimizer.Wpf.Views"
        Title="Inställningar"
        Width="550"
        Height="725"
        MinWidth="550"
        MinHeight="725"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Background="{StaticResource BrushBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#11141A"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="22,18">
            <StackPanel>
                <TextBlock Text="Inställningar"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrushText}" />
                <TextBlock Text="Tibber, home och proxy"
                           Style="{StaticResource MutedText}"
                           Margin="0,5,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="18">

                <Border Style="{StaticResource CardCompact}">
                    <StackPanel>
                        <TextBlock Text="Tibber"
                                   Style="{StaticResource SectionTitle}" />

                        <views:TokenBox Label="Tibber token"
                                        Token="{Binding TibberToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Home"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" />

                        <ComboBox ItemsSource="{Binding Homes}"
                                  SelectedItem="{Binding SelectedHome}"
                                  DisplayMemberPath="NicknameText"
                                  MaxDropDownHeight="260" />

                        <Button Content="Ladda Tibber homes"
                                Command="{Binding LoadHomesCommand}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardCompact}">
                    <StackPanel>
                        <TextBlock Text="Proxy"
                                   Style="{StaticResource SectionTitle}" />

                        <CheckBox Content="Använd proxy"
                                  IsChecked="{Binding UseProxy}" />

                        <TextBlock Text="Proxyadress"
                                   Style="{StaticResource MutedText}" />
                        <TextBox Text="{Binding ProxyAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardCompact}">
                    <StackPanel>
                        <TextBlock Text="Info"
                                   Style="{StaticResource SectionTitle}" />

                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#11141A"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Valt home sparas automatiskt när du byter."
                           Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Content="Spara"
                        Command="{Binding SaveSettingsCommand}"
                        Margin="0,0,8,0" />

                <Button Grid.Column="2"
                        Content="Stäng"
                        Style="{StaticResource PrimaryButton}"
                        Click="CloseButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>